# Copy this file to `.env` and fill in real values. `.env` is gitignored — NEVER commit it.
# Only secrets and machine-specific overrides belong here; non-secret defaults live in
# config/config.yaml. Anything set here overrides config.yaml.
#
# NOTE: every key is prefixed OPTIONS_ so this project's config stays isolated from any
# global/ambient shell variables of the same base name.

# --- Trading mode: locked to "paper". Setting anything else makes the app refuse to start. ---
OPTIONS_MODE=paper

# --- Instrument traded in Phase 1 (MES or MNQ). ---
OPTIONS_INSTRUMENT=MES

# --- IBKR paper connection. IB Gateway paper API = 4002; TWS paper = 7497. ---
OPTIONS_IBKR_HOST=127.0.0.1
OPTIONS_IBKR_PORT=4002
OPTIONS_IBKR_CLIENT_ID=1

# --- IBKR paper login for IBC auto-login (OPTIONAL). Leave blank to log in by ---
# --- hand in the IB Gateway window instead. Password is only ever written to a ---
# --- tmpfs file at launch (mode 600), never to disk or git. ---
OPTIONS_IBKR_USERNAME=
OPTIONS_IBKR_PASSWORD=

# --- Databento API key (CME historical data; needed in a later phase). ---
OPTIONS_DATABENTO_API_KEY=

# --- Finnhub API key (news/macro; needed in a later phase). ---
OPTIONS_FINNHUB_API_KEY=

# --- Telegram bot token from @BotFather (alerts). Use a bot dedicated to this system. ---
OPTIONS_TELEGRAM_BOT_TOKEN=

# --- Telegram chat ID to send alerts to (your user/group id). ---
OPTIONS_TELEGRAM_CHAT_ID=
